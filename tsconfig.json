{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@api/*": ["./src/shared/api/*"],
      "@modules/*": ["./src/modules/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "app.d.ts"]
}
