{
  "expo": {
    "name": "ClassConnect Pro",
    "slug": "classconnect-pro",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "classconnect",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": ["android.permission.INTERNET"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2544DB"
      },
      "package": "com.classconnect.pro"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": ["expo-secure-store", "expo-localization", "expo-font"],
    "extra": {
      "eas": {
        "projectId": "5dfb70af-788a-4b3b-9e1c-5f7a5e74760d"
      }
    },
    "owner": "connectclass7",
    "updates": {
      "url": "https://u.expo.dev/5dfb70af-788a-4b3b-9e1c-5f7a5e74760d"
    }
  }
}
